<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- account.payment.register Wizard -->
    <record id="view_account_payment_register_bimonetario" model="ir.ui.view">
        <field name="name">account.payment.register.form.bimonetario</field>
        <field name="model">account.payment.register</field>
        <field name="inherit_id" ref="account.view_account_payment_register_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount']" position="after">
                <field name="l10n_ve_ta_multicurrency_fiscal_id" invisible="1"/>
                <field name="l10n_ve_ta_multicurrency_use_manual_rate"/>
                <field name="l10n_ve_ta_multicurrency_rate"
                       invisible="not l10n_ve_ta_multicurrency_use_manual_rate"/>
                <field name="l10n_ve_ta_multicurrency_amount"
                       string="Total Ref."
                       options="{'currency_field': 'l10n_ve_ta_multicurrency_fiscal_id'}"/>
            </xpath>
        </field>
    </record>

    <!-- account.payment Final Record -->
    <record id="view_account_payment_form_bimonetario" model="ir.ui.view">
        <field name="name">account.payment.form.bimonetario</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date']" position="after">
                <field name="l10n_ve_ta_multicurrency_fiscal_id" invisible="1"/>
                <field name="l10n_ve_ta_multicurrency_equivalent_id" invisible="1"/>
                <field name="l10n_ve_ta_multicurrency_prev_currency_id" invisible="1"/>
                <field name="l10n_ve_ta_multicurrency_use_manual_rate"
                       readonly="state != 'draft'"/>
                <field name="l10n_ve_ta_multicurrency_rate"
                       invisible="not l10n_ve_ta_multicurrency_use_manual_rate"
                       readonly="state != 'draft'"/>
                <field name="l10n_ve_ta_multicurrency_amount"
                       string="Total Ref."
                       options="{'currency_field': 'l10n_ve_ta_multicurrency_equivalent_id'}"/>
            </xpath>
        </field>
    </record>

    <!-- Injection into Account Payment List (Tree) View -->
    <record id="view_account_payment_tree_bimonetario" model="ir.ui.view">
        <field name="name">account.payment.tree.bimonetario</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_company_currency_signed']" position="after">
                <field name="l10n_ve_ta_multicurrency_equivalent_id" column_invisible="True"/>
                <field name="l10n_ve_ta_multicurrency_amount" string="Total Ref." sum="Total" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
