<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_form_multicurrency" model="ir.ui.view">
        <field name="name">purchase.order.form.multicurrency</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='order_line']/list/field[@name='price_subtotal']" position="after">
                <field name="l10n_ve_ta_multicurrency_fiscal_id" column_invisible="True"/>
                <field name="l10n_ve_ta_multicurrency_order_currency_id" column_invisible="True"/>
                <!-- Document Currency columns -->
                <field name="l10n_ve_ta_multicurrency_taxable_amount_curr" string="Gravable" optional="show" sum="Total Gravable"
                       widget="monetary" options="{'currency_field': 'l10n_ve_ta_multicurrency_order_currency_id'}"/>
                <field name="l10n_ve_ta_multicurrency_exempt_amount_curr" string="Exento" optional="show" sum="Total Exento"
                       widget="monetary" options="{'currency_field': 'l10n_ve_ta_multicurrency_order_currency_id'}"/>
                <field name="l10n_ve_ta_multicurrency_tax_amount_curr" string="Impuesto" optional="show" sum="Total Impuesto"
                       widget="monetary" options="{'currency_field': 'l10n_ve_ta_multicurrency_order_currency_id'}"/>

                <!-- Reference Currency columns (Bs.F) -> Hidden by default -->
                <field name="l10n_ve_ta_multicurrency_price_unit" optional="hide"
                       widget="monetary" options="{'currency_field': 'l10n_ve_ta_multicurrency_fiscal_id'}"/>
                <field name="l10n_ve_ta_multicurrency_taxable_amount" optional="hide" sum="Total Ref."
                       widget="monetary" options="{'currency_field': 'l10n_ve_ta_multicurrency_fiscal_id'}"/>
                <field name="l10n_ve_ta_multicurrency_exempt_amount"  optional="hide" sum="Total Ref."
                       widget="monetary" options="{'currency_field': 'l10n_ve_ta_multicurrency_fiscal_id'}"/>
                <field name="l10n_ve_ta_multicurrency_discount_amount" optional="hide" sum="Total Ref."
                       widget="monetary" options="{'currency_field': 'l10n_ve_ta_multicurrency_fiscal_id'}"/>
                <field name="l10n_ve_ta_multicurrency_tax_amount" optional="hide" sum="Total Ref."
                       widget="monetary" options="{'currency_field': 'l10n_ve_ta_multicurrency_fiscal_id'}"/>
            </xpath>

            <!-- Check tasa manual al final de la columna derecha (igual que en ventas) -->
            <xpath expr="//field[@name='date_order']/.." position="inside">
                <field name="l10n_ve_ta_multicurrency_prev_currency_id" invisible="1"/>
                <field name="l10n_ve_ta_multicurrency_prev_manual_rate" invisible="1"/>
                <field name="l10n_ve_ta_multicurrency_use_manual_rate" readonly="state in ['cancel', 'done', 'purchase']"/>
                <field name="l10n_ve_ta_multicurrency_rate"
                       invisible="not l10n_ve_ta_multicurrency_use_manual_rate" readonly="state in ['cancel', 'done', 'purchase']"/>
            </xpath>

            <!-- Multicurrency Totals Card (Integrated into Footer) -->
            <xpath expr="//group[hasclass('oe_subtotal_footer')]" position="inside">
                <field name="l10n_ve_ta_multicurrency_show_summary" invisible="1"/>
                <field name="l10n_ve_ta_multicurrency_fiscal_id" invisible="1"/>

                <!-- Separator and Bimonetary Section -->
                <div class="border-top mt-3 mb-2" colspan="2"
                     invisible="not l10n_ve_ta_multicurrency_show_summary"
                     style="border-top: 1px solid #ccc !important;"/>

                <field name="l10n_ve_ta_multicurrency_summary_title" readonly="1" nolabel="1" colspan="2" 
                       class="text-primary fw-bold fs-5 mb-2" invisible="not l10n_ve_ta_multicurrency_show_summary"/>

                <field name="l10n_ve_ta_multicurrency_taxable_amount" string="Gravable" decoration-bf="1"
                       invisible="not l10n_ve_ta_multicurrency_show_summary"
                       widget="monetary" options="{'currency_field': 'l10n_ve_ta_multicurrency_fiscal_id'}"/>

                <field name="l10n_ve_ta_multicurrency_exempt_amount" string="Exento"
                       invisible="not l10n_ve_ta_multicurrency_show_summary"
                       widget="monetary" options="{'currency_field': 'l10n_ve_ta_multicurrency_fiscal_id'}"/>

                <field name="l10n_ve_ta_multicurrency_discount_amount" string="Descuento"
                       invisible="not l10n_ve_ta_multicurrency_show_summary"
                       widget="monetary" options="{'currency_field': 'l10n_ve_ta_multicurrency_fiscal_id'}"/>

                <field name="l10n_ve_ta_multicurrency_untaxed_amount" string="Subtotal" class="oe_subtotal_footer_separator" decoration-bf="1"
                       invisible="not l10n_ve_ta_multicurrency_show_summary"
                       widget="monetary" options="{'currency_field': 'l10n_ve_ta_multicurrency_fiscal_id'}"/>

                <field name="l10n_ve_ta_multicurrency_tax_amount" string="IVA"
                       invisible="not l10n_ve_ta_multicurrency_show_summary"
                       widget="monetary" options="{'currency_field': 'l10n_ve_ta_multicurrency_fiscal_id'}"/>

                <field name="l10n_ve_ta_multicurrency_total_amount" string="Total" class="oe_subtotal_footer_separator" decoration-bf="1"
                       invisible="not l10n_ve_ta_multicurrency_show_summary"
                       widget="monetary" options="{'currency_field': 'l10n_ve_ta_multicurrency_fiscal_id'}"/>
            </xpath>

            <xpath expr="//form" position="inside">
                <style>
                    /* Hide Odoo's native multicurrency conversion / secondary currency lines in the footer */
                    .oe_subtotal_footer .text-muted,
                    .oe_subtotal_footer [class*="text-muted"],
                    .oe_subtotal_footer br,
                    div[name="tax_totals"] td:last-child span:not(:first-child),
                    div[name="tax_totals"] td:last-child div:not(:first-child),
                    div[name="tax_totals"] tr:has(.text-muted),
                    div[name="tax_totals"] tr:has(span:nth-child(2)),
                    .oe_subtotal_footer .oe_subtotal_footer_separator + .text-muted,
                    .oe_subtotal_footer_separator + .text-muted,
                    .oe_subtotal_footer_separator + br + span,
                    .oe_subtotal_footer_separator + span:nth-of-type(n+2) {
                        display: none !important;
                    }
                </style>
            </xpath>



        </field>
    </record>

    <!-- Injection into Purchase Order List (Tree) View -->
    <record id="view_purchase_order_tree_multicurrency" model="ir.ui.view">
        <field name="name">purchase.order.tree.multicurrency</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_total']" position="after">
                <field name="l10n_ve_ta_multicurrency_fiscal_id" column_invisible="True"/>
                <field name="l10n_ve_ta_multicurrency_total_amount" sum="Total" optional="show"
                       widget="monetary" options="{'currency_field': 'l10n_ve_ta_multicurrency_fiscal_id'}"/>
            </xpath>
        </field>
    </record>

    <record id="view_purchase_order_kpis_tree_multicurrency" model="ir.ui.view">
        <field name="name">purchase.order.kpis.tree.multicurrency</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_total']" position="after">
                <field name="l10n_ve_ta_multicurrency_fiscal_id" column_invisible="True"/>
                <field name="l10n_ve_ta_multicurrency_total_amount" sum="Total" optional="show"
                       widget="monetary" options="{'currency_field': 'l10n_ve_ta_multicurrency_fiscal_id'}"/>
            </xpath>
        </field>
    </record>

    <record id="view_purchase_order_view_tree_multicurrency" model="ir.ui.view">
        <field name="name">purchase.order.view.tree.multicurrency</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_total']" position="after">
                <field name="l10n_ve_ta_multicurrency_fiscal_id" column_invisible="True"/>
                <field name="l10n_ve_ta_multicurrency_total_amount" sum="Total" optional="show"
                       widget="monetary" options="{'currency_field': 'l10n_ve_ta_multicurrency_fiscal_id'}"/>
            </xpath>
        </field>
    </record>
</odoo>
