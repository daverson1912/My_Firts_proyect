<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_batch_payment_tree_bimonetario" model="ir.ui.view">
        <field name="name">account.batch.payment.tree.bimonetario</field>
        <field name="model">account.batch.payment</field>
        <field name="inherit_id" ref="account_batch_payment.view_batch_payment_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount']" position="after">
                <field name="l10n_ve_ta_multicurrency_batch_fiscal_id" invisible="1"/>
                <field name="l10n_ve_ta_multicurrency_amount" string="Total Ref." sum="Total" optional="show"/>
            </xpath>
        </field>
    </record>
    <record id="view_batch_payment_search_bimonetario" model="ir.ui.view">
        <field name="name">account.batch.payment.search.bimonetario</field>
        <field name="model">account.batch.payment</field>
        <field name="inherit_id" ref="account_batch_payment.view_batch_payment_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='journal_id']" position="after">
                <field name="l10n_ve_ta_multicurrency_batch_fiscal_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_batch_payment_form_bimonetario" model="ir.ui.view">
        <field name="name">account.batch.payment.form.bimonetario</field>
        <field name="model">account.batch.payment</field>
        <field name="inherit_id" ref="account_batch_payment.view_batch_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='journal_id']" position="after">
                <field name="l10n_ve_ta_multicurrency_batch_fiscal_id" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='payment_ids']/list/field[@name='amount_signed']" position="after">
                <field name="l10n_ve_ta_multicurrency_fiscal_id" column_invisible="1"/>
                <field name="l10n_ve_ta_multicurrency_amount" string="Total Ref." sum="Total" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
