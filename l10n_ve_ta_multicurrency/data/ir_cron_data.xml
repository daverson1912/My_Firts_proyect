<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_l10n_ve_ta_multicurrency_sync_rate" model="ir.cron">
            <field name="name">Sincronización de Tasa BCV</field>
            <field name="model_id" ref="base.model_res_currency"/>
            <field name="state">code</field>
            <field name="code">model.action_l10n_ve_ta_multicurrency_sync_bcv_rates()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">12</field>
            <field name="interval_type">hours</field>
            <field name="nextcall" eval="(datetime.now().replace(hour=11, minute=30, second=0)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
