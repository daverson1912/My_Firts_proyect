<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Formulario: pestaña Configuración Avanzada -->
    <record id="view_journal_form_inherit_l10n_ve_fiscal" model="ir.ui.view">
        <field name="name">account.journal.form.inherit.l10n.ve.fiscal</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='advanced_settings']" position="inside">
                <separator string="Libros Fiscales Venezuela"/>
                <group>
                    <field name="l10n_ve_affects_sales_ledger"/>
                    <field name="l10n_ve_affects_purchase_ledger"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Lista: columnas de libros fiscales -->
    <record id="view_journal_list_inherit_l10n_ve_fiscal" model="ir.ui.view">
        <field name="name">account.journal.list.inherit.l10n.ve.fiscal</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="l10n_ve_affects_sales_ledger" string="Libro Venta" optional="show"/>
                <field name="l10n_ve_affects_purchase_ledger" string="Libro Compra" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
