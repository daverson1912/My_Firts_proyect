<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Vista de Búsqueda para Unificador -->
    <record id="view_wh_iva_unifier_search" model="ir.ui.view">
        <field name="name">account.wh.iva.unifier.search</field>
        <field name="model">account.wh.iva</field>
        <field name="arch" type="xml">
            <search string="Unificador de Retenciones">
                
                <!-- Campos de búsqueda principal - SIEMPRE VISIBLES -->
                <field name="partner_id" string="Proveedor (Código o Nombre)" 
                       filter_domain="['|', '|', ('partner_id', 'ilike', self), ('partner_vat', 'ilike', self), ('partner_id.ref', 'ilike', self)]"/>
                <field name="name" string="Nº Retención"/>
                <field name="partner_vat" string="RIF"/>
                <field name="date" string="Fecha" filter_domain="[]" context="{}"/>
                
                <!-- Separador visual -->
                <separator/>
                
                <!-- Filtros de Estado - EXPANDIDOS y VISIBLES -->
                <filter string="Todos" name="all" 
                        domain="[]"/>
                <filter string="Pendiente" name="draft" 
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Generadas" name="posted" 
                        domain="[('state', '=', 'posted')]"/>
                
                <separator/>
                
                <!-- Filtros de Fecha con widget mejorado -->
                <filter string="Rango de Fechas" name="filter_date" date="date"/>
                
                <separator/>
                
                <!-- Agrupaciones -->
                <group expand="0" string="Agrupar Por">
                    <filter string="Proveedor" name="group_partner" 
                            context="{'group_by': 'partner_id'}"/>
                    <filter string="Estado" name="group_state" 
                            context="{'group_by': 'state'}"/>
                    <filter string="Mes" name="group_date" 
                            context="{'group_by': 'date:month'}"/>
                </group>
                
            </search>
        </field>
    </record>
    
    <!-- Vista de Lista para Unificador -->
    <record id="view_wh_iva_unifier_tree" model="ir.ui.view">
        <field name="name">account.wh.iva.unifier.tree</field>
        <field name="model">account.wh.iva</field>
        <field name="arch" type="xml">
            <list string="Comprobantes de Retención" 
                  decoration-warning="state == 'draft'" 
                  decoration-success="state == 'posted'"
                  create="false"
                  delete="false">
                
                <header>
                    <button name="action_unify" string="Unificar" type="object" class="oe_highlight"/>
                </header>
                
                <!-- Columnas principales -->
                <field name="name" string="Retención" width="120px"/>
                <field name="date" string="Fecha" width="100px"/>
                <field name="partner_vat" string="Código" width="120px"/>
                <field name="partner_id" string="Proveedor" width="200px"/>
                <field name="invoice_number" string="Documento" width="150px"/>
                <field name="amount_total_invoice" string="Monto Documento" width="120px" sum="Total Documentos"/>
                <field name="amount_taxable_base" string="Base Imponible" width="120px" sum="Total Base Imponible"/>
                <field name="amount_exempt" string="Exento" width="100px" sum="Total Exento"/>
                <field name="amount_base" string="Base Impuesto" width="120px" sum="Total Base"/>
                <field name="amount_total_ret" string="Monto Retenido" width="120px" sum="Total Retenido"/>
                <field name="retention_percentage" string="% Retención" width="80px"/>
                <field name="state" string="Estado" widget="badge" 
                       decoration-warning="state == 'draft'" 
                       decoration-success="state == 'posted'" 
                       width="90px"/>
                
                <!-- Campos ocultos para filtros y ordenamiento -->
                <field name="currency_id" column_invisible="1"/>
                <field name="company_id" column_invisible="1"/>
                
            </list>
        </field>
    </record>
    
    <!-- Acción de Ventana para Unificador -->
    <record id="action_wh_iva_unifier" model="ir.actions.act_window">
        <field name="name">Unificador de Retenciones</field>
        <field name="res_model">account.wh.iva</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_wh_iva_unifier_tree"/>
        <field name="search_view_id" ref="view_wh_iva_unifier_search"/>
        <field name="domain">[('type', '=', 'purchase')]</field>
        <field name="context">{
            'search_default_draft': 1,
            'search_default_filter_date': 1,
            'group_by': 'partner_id',
            'default_type': 'purchase',
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay comprobantes de retención para mostrar
            </p>
            <p>
                Use los filtros para buscar comprobantes por fecha, estado o proveedor.
            </p>
        </field>
    </record>
    
</odoo>
