<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- ========== VISTA DE FORMULARIO ========== -->
    
    <record id="view_account_wh_islr_form" model="ir.ui.view">
        <field name="name">account.wh.islr.form</field>
        <field name="model">account.wh.islr</field>
        <field name="arch" type="xml">
            <form string="Comprobante de Retención de ISLR">
                <header>
                    <button name="action_process_withholding"
                            string="Editar Retención"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            groups="account.group_account_manager"/>
                    <button name="action_enable_detail_edit"
                            string="Modificar Montos del Detalle"
                            type="object"
                            class="btn-secondary"
                            invisible="edit_detail_mode or state not in ('draft','posted')"
                            groups="account.group_account_manager"/>
                    <button name="action_apply_detail_changes"
                            string="Aplicar Cambios"
                            type="object"
                            class="btn-primary"
                            invisible="not edit_detail_mode"
                            groups="account.group_account_manager"/>
                    <button name="action_reset_to_draft"
                            string="Volver a Borrador"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'posted' or type != 'purchase'"
                            groups="account.group_account_manager"/>
                    <button name="action_print_retention"
                            string="Imprimir Comprobante"
                            type="object"
                            invisible="state == 'draft' or type != 'purchase'"
                            groups="account.group_account_manager"/>
                    <button name="action_retry_email"
                            string="Reintentar Envío"
                            type="object"
                            class="btn-secondary"
                            icon="fa-refresh"
                            invisible="email_state != 'failed'"
                            groups="account.group_account_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,posted,declared"/>
                </header>
                <sheet>
                    <!-- Correlativos ISLR (solo compras) -->
                    <group invisible="type != 'purchase'" class="o_inner_group">
                        <group string="Correlativos ISLR">
                            <field name="next_correlative" readonly="1" string="Próximo Correlativo"/>
                        </group>
                    </group>

                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Número de Comprobante" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group name="main_info">
                            <field name="partner_id" options="{'no_create': True}"/>
                            <field name="partner_vat"/>
                            <field name="date" readonly="state in ('declared', 'cancel')"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="edit_detail_mode" invisible="1"/>
                        </group>
                        <group name="extra_info">
                            <field name="company_id" groups="base.group_multi_company" readonly="1"/>
                            <field name="api_transaction_id" invisible="not api_transaction_id"/>
                        </group>
                    </group>
                    
                    <group string="DOCUMENTO RELACIONADO">
                        <group>
                            <field name="move_id" readonly="1" string="Factura de Compra"/>
                            <field name="invoice_number"/>
                        </group>
                        <group>
                            <field name="invoice_date"/>
                            <field name="wh_type"/>
                        </group>
                    </group>

                    <group string="RESUMEN DE MONTOS">
                        <group name="amounts_left">
                            <field name="amount_total_invoice" string="Monto del Documento"/>
                            <field name="amount_taxable_base" string="Base Imponible"/>
                            <field name="amount_exempt" string="Monto Exento"/>
                        </group>
                        <group name="amounts_right">
                            <field name="amount_total_ret" string="Total Retenido" class="oe_subtotal_footer_separator"/>
                            <field name="amount_to_pay" string="Monto a Pagar" widget="monetary" decoration-bf="1"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="DETALLE DE RETENCIÓN" name="detail">
                            <div class="alert alert-warning mb-2" role="alert" invisible="not edit_detail_mode">
                                <strong>✏️ Modo edición activo.</strong>
                                Modifique los campos directamente en la tabla. El <strong>Total Retenido</strong> se actualizará automáticamente al guardar cada línea. Al terminar, haga clic en <strong>Aplicar Cambios</strong> para confirmar y registrar en contabilidad.
                            </div>
                            <field name="line_ids" readonly="not edit_detail_mode">
                                <list create="0" delete="0">
                                    <field name="product_id" readonly="1"/>
                                    <field name="move_line_id" string="Ítem Factura" optional="hide" readonly="1"/>
                                    <field name="concept_id" readonly="1"/>
                                    <field name="fiscal_code" string="Código"/>
                                    <field name="base_amount" string="Base Imponible" readonly="1" sum="Total Bruto"/>
                                    <!-- Columnas modo lectura -->
                                    <field name="subject_amount_display" string="Base de la retención" column_invisible="parent.edit_detail_mode"/>
                                    <field name="retention_calculation_display" string="Calc. Imp" column_invisible="parent.edit_detail_mode"/>
                                    <!-- Columnas modo edición -->
                                    <field name="subject_amount_percentage" string="% Base Sujeta" column_invisible="not parent.edit_detail_mode"/>
                                    <field name="retention_percentage" string="% Retención" column_invisible="not parent.edit_detail_mode"/>
                                    <field name="subtrahend" string="Sustraendo" sum="Total Sustraendo"/>
                                    <field name="retention_amount" string="Monto Retenido" sum="Total Retenido"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                                <form>
                                    <group>
                                        <group>
                                            <field name="product_id" readonly="1"/>
                                            <field name="move_line_id" readonly="1"/>
                                            <field name="concept_id" readonly="1"/>
                                            <field name="fiscal_code"/>
                                            <field name="subject_amount_percentage" string="% Base Sujeta"/>
                                            <field name="retention_percentage" string="% Retención"/>
                                        </group>
                                        <group>
                                            <field name="base_amount" string="Base Imponible" readonly="1"/>
                                            <field name="subject_amount_display" string="Base Retención (display)" readonly="1"/>
                                            <field name="retention_calculation_display" string="Calc. Imp (display)" readonly="1"/>
                                            <field name="subtrahend"/>
                                            <field name="retention_amount"/>
                                        </group>
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>

                    <div class="alert alert-info" role="alert" invisible="state != 'draft'">
                         <p><strong>ℹ️ Comprobante en Borrador</strong></p>
                         <p>Este comprobante fue creado automáticamente al confirmar la factura.</p>
                         <p>Puede editar su retención haciendo clic en el botón "Editar Retención".</p>
                    </div>
                    <!-- Estado de Correo -->
                    <group string="Estado de Correo Electrónico" invisible="state == 'draft'">
                        <group>
                            <field name="email_state" widget="badge"
                                   decoration-warning="email_state == 'pending'"
                                   decoration-success="email_state == 'sent'"
                                   decoration-danger="email_state == 'failed'"
                                   decoration-muted="email_state == 'skipped'"/>
                            <field name="last_email_at" invisible="not last_email_at"/>
                        </group>
                        <group>
                            <field name="email_retry_count" invisible="email_retry_count == 0"/>
                            <field name="last_email_error" invisible="not last_email_error"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    
    <!-- ========== VISTA DE LISTA ========== -->
    
    <record id="view_account_wh_islr_tree" model="ir.ui.view">
        <field name="name">account.wh.islr.tree</field>
        <field name="model">account.wh.islr</field>
        <field name="arch" type="xml">
            <list string="Comprobantes de Retención de ISLR">
                <field name="date" string="Fecha"/>
                <field name="name" string="Número"/>
                <field name="invoice_number" string="Nro. Documento"/>
                <field name="partner_id" string="Contacto"/>
                <field name="partner_vat"/>
                <field name="amount_total_invoice" string="Total Factura" sum="Total Bruto" optional="show"/>
                <field name="amount_total_ret" string="Monto Retenido" sum="Total Retenido"/>
                <field name="amount_to_pay" string="Total a Pagar" sum="Total Neto" optional="show"/>
                <field name="email_state" string="Correo" widget="badge" 
                       decoration-warning="email_state == 'pending'" 
                       decoration-success="email_state == 'sent'"
                       decoration-danger="email_state == 'failed'"
                       optional="show"/>
                <field name="state" widget="badge" 
                       decoration-info="state == 'draft'" 
                       decoration-success="state == 'posted'"
                       decoration-primary="state == 'declared'"/>
            </list>
        </field>
    </record>
    
    <!-- ========== VISTA DE BÚSQUEDA ========== -->
    
    <record id="view_account_wh_islr_search" model="ir.ui.view">
        <field name="name">account.wh.islr.search</field>
        <field name="model">account.wh.islr</field>
        <field name="arch" type="xml">
            <search string="Buscar Comprobantes ISLR">
                <field name="name" string="Número"/>
                <field name="partner_id" string="Contacto"/>
                <field name="move_id" string="Factura"/>
                <filter name="state_draft" string="Borrador" domain="[('state', '=', 'draft')]"/>
                <filter name="state_posted" string="Publicado" domain="[('state', '=', 'posted')]"/>
                <filter name="state_declared" string="Declarado" domain="[('state', '=', 'declared')]"/>
                <separator/>
                <filter name="email_pending" 
                        string="Correo Pendiente" 
                        domain="[('email_state', '=', 'pending')]"/>
                <filter name="email_sent" 
                        string="Correo Enviado" 
                        domain="[('email_state', '=', 'sent')]"/>
                <filter name="email_failed" 
                        string="Correo Fallido" 
                        domain="[('email_state', '=', 'failed')]"/>
                <separator/>
                <group expand="0" string="Agrupar Por">
                    <filter name="group_partner" string="Contacto" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_date" string="Fecha" context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ========== RESUMEN DE COMPROBANTES (SQL VIEW) ========== -->

    <record id="view_account_wh_islr_summary_tree" model="ir.ui.view">
        <field name="name">account.wh.islr.summary.tree</field>
        <field name="model">account.wh.islr.summary</field>
        <field name="arch" type="xml">
            <list string="Comprobantes de Retención ISLR" create="false" edit="false" delete="false">
                <field name="name" string="Comprobante"/>
                <field name="date" string="Fecha"/>
                <field name="partner_id" string="Contacto"/>
                <field name="amount_total_invoice" string="Monto Documento" sum="Total Bruto"/>
                <field name="amount_total_ret" string="Monto Retenido" sum="Total Retenido"/>
                <field name="amount_to_pay" string="Total a Pagar" sum="Total Neto"/>
                <field name="state" widget="badge" 
                       decoration-success="state == 'posted'" 
                       decoration-info="state == 'declared'"/>
                <field name="currency_id" column_invisible="1"/>
                <button name="action_print_retention" string="Imprimir" type="object" icon="fa-print"/>
            </list>
        </field>
    </record>

    <record id="view_account_wh_islr_summary_form" model="ir.ui.view">
        <field name="name">account.wh.islr.summary.form</field>
        <field name="model">account.wh.islr.summary</field>
        <field name="arch" type="xml">
            <form string="Comprobante de Retención ISLR" create="false" edit="false" delete="false">
                <header>
                    <button name="action_requeue_email" string="Reenviar por Correo" type="object" class="oe_highlight" icon="fa-envelope"/>
                    <button name="action_print_retention" string="Imprimir Reporte" type="object" icon="fa-print"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id" readonly="1"/>
                            <field name="date" readonly="1"/>
                        </group>
                        <group>
                            <field name="amount_total_invoice" widget="monetary" string="Monto del Documento"/>
                            <field name="amount_taxable_base" widget="monetary" string="Base Imponible Total"/>
                            <field name="amount_exempt" widget="monetary" string="Monto Exento Total"/>
                            <field name="amount_total_ret" widget="monetary" string="Total Retenido"/>
                            <field name="amount_to_pay" widget="monetary" string="Monto Neto a Pagar" class="oe_subtotal_footer_separator"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Facturas Consolidadas">
                            <field name="line_ids">
                                <list string="Documentos" create="false" edit="false" delete="false">
                                    <field name="move_id" string="Factura de Origen"/>
                                    <field name="invoice_number" string="Número"/>
                                    <field name="invoice_date" string="Fecha"/>
                                    <field name="amount_total_ret" sum="Total"/>
                                    <field name="state" widget="badge" 
                                           decoration-success="state == 'posted'" 
                                           decoration-info="state == 'declared'"
                                           decoration-warning="state == 'draft'"
                                           decoration-danger="state == 'cancel'"/>
                                </list>
                            </field>
                        </page>
                        <page string="Detalle de Retención" name="retention_lines_detail">
                            <field name="detail_line_ids">
                                <list string="Detalle de Ítems" create="false" edit="false" delete="false">
                                    <field name="invoice_number" string="Factura"/>
                                    <field name="concept_id" string="Concepto"/>
                                    <field name="product_id" string="Producto"/>
                                    <field name="base_amount" string="Base de Retención" sum="Total Base"/>
                                    <field name="subject_amount_display" string="Monto Sujeto"/>
                                    <field name="retention_calculation_display" string="Impuesto Retenido"/>
                                    <field name="subtrahend" string="Sustraendo" sum="Total Sustraendo"/>
                                    <field name="retention_amount" string="Retención Neta" sum="Total Retención"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_account_wh_islr_summary_search" model="ir.ui.view">
        <field name="name">account.wh.islr.summary.search</field>
        <field name="model">account.wh.islr.summary</field>
        <field name="arch" type="xml">
            <search string="Buscar Comprobantes ISLR">
                <field name="name" string="Número"/>
                <field name="partner_id" string="Contacto"/>
                <group expand="0" string="Agrupar Por">
                    <filter name="group_partner" string="Contacto" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_date" string="Fecha" context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_account_wh_islr_summary_grouped" model="ir.actions.act_window">
        <field name="name">Comprobantes de Retención ISLR</field>
        <field name="res_model">account.wh.islr.summary</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_account_wh_islr_summary_tree"/>
        <field name="search_view_id" ref="view_account_wh_islr_summary_search"/>
        <field name="domain">[('type', '=', 'purchase')]</field>
        <field name="context">{'default_type': 'purchase'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay comprobantes de retención de ISLR para mostrar
            </p>
        </field>
    </record>

</odoo>
