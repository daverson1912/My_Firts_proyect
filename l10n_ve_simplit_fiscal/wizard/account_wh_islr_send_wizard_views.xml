<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_wh_islr_send_wizard_form" model="ir.ui.view">
        <field name="name">account.wh.islr.send.wizard.form</field>
        <field name="model">account.wh.islr.send.wizard</field>
        <field name="arch" type="xml">
            <form string="Enviar Comprobantes ISLR por Correo">
                <p class="oe_grey">
                    Se enviará el comprobante de retención ISLR a los siguientes proveedores utilizando la plantilla estándar.
                </p>
                <field name="line_ids">
                    <list editable="bottom" create="false" delete="true">
                        <field name="summary_name" readonly="1" force_save="1"/>
                        <field name="partner_name" readonly="1" force_save="1"/>
                        <field name="email" widget="email"/>
                    </list>
                </field>
                <footer>
                    <button name="action_send_emails" string="Enviar Correos" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_account_wh_islr_send_wizard" model="ir.actions.act_window">
        <field name="name">Enviar Retenciones ISLR Masivas</field>
        <field name="res_model" >account.wh.islr.send.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="l10n_ve_simplit_fiscal.model_account_wh_islr_summary"/>
        <field name="binding_view_types">list</field>
    </record>
</odoo>
