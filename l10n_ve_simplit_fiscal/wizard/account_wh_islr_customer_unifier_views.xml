<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_wh_islr_customer_unifier_form" model="ir.ui.view">
        <field name="name">account.wh.islr.customer.unifier.form</field>
        <field name="model">account.wh.islr.customer.unifier</field>
        <field name="arch" type="xml">
            <form string="Cargar Comprobante de Retención ISLR">
                <sheet>
                    <div class="alert alert-info" role="alert" style="margin-bottom:15px;">
                        <i class="fa fa-calendar me-1"/> 
                        <strong>Fecha del Comprobante:</strong> Ingrese la fecha en que el cliente le entregó el comprobante físico.
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="number" placeholder="Ej: 202605000001"/>
                        </group>
                        <group>
                            <field name="date"/>
                        </group>
                    </group>
                    
                    <separator string="Facturas Asociadas"/>
                    <field name="wh_islr_ids" readonly="1">
                        <list>
                            <field name="invoice_number" string="Nro Factura"/>
                            <field name="date" string="Fecha Doc."/>
                            <field name="amount_total_invoice" string="Monto Doc." sum="Total"/>
                            <field name="amount_total_ret" string="Monto Retenido" sum="Total Retenido"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Guardar Comprobante" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
