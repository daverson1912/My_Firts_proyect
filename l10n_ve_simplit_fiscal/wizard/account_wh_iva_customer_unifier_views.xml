<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_wh_iva_customer_unifier_form" model="ir.ui.view">
        <field name="name">account.wh.iva.customer.unifier.form</field>
        <field name="model">account.wh.iva.customer.unifier</field>
        <field name="arch" type="xml">
            <form string="Guardar Comprobante">
                <sheet>
                    <div class="alert alert-info" role="alert" style="margin-bottom:15px;">
                        <i class="fa fa-info-circle me-1"/>
                        <strong>Formato Requerido:</strong> 14 dígitos (Año + Mes + 8 dígitos correlativos).
                        Ejemplo: <code style="font-size: 1.1em;">20260500000001</code>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="wh_number" placeholder="Ej: 20260500000001"/>
                        </group>
                        <group>
                            <field name="date" required="1"/>
                            <field name="retention_registration_date" required="1"/>
                        </group>
                    </group>
                    
                    <separator string="Facturas Asociadas"/>
                    <field name="wh_iva_ids" readonly="1">
                        <list>
                            <field name="invoice_number" string="Nro Factura"/>
                            <field name="date" string="Fecha Doc."/>
                            <field name="amount_total_invoice" string="Monto Doc." sum="Total"/>
                            <field name="amount_total_ret" string="Monto Retenido" sum="Total Retenido"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Registrar Comprobante" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
