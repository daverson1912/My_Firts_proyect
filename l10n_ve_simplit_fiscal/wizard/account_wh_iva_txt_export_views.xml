<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- VISTA FORMULARIO DEL WIZARD -->
    <record id="view_account_wh_iva_txt_export_wizard_form" model="ir.ui.view">
        <field name="name">account.wh.iva.txt.export.wizard.form</field>
        <field name="model">account.wh.iva.txt.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Exportar TXT de IVA (SENIAT)">
                <sheet>
                    <div class="alert alert-info" role="alert" invisible="state != 'draft'">
                        <p>Se generará el archivo TXT para los <strong><field name="wh_iva_ids" widget="statinfo" string="registros" class="oe_inline"/></strong> seleccionados.</p>
                        <p>Los datos se enviarán al API de Simplit Fiscal para su procesamiento.</p>
                    </div>

                    <div class="alert alert-success" role="alert" invisible="state != 'done'">
                        <p><strong>✅ Archivo generado exitosamente.</strong></p>
                        <p>Haga clic en el enlace de abajo para descargar el archivo TXT.</p>
                    </div>

                    <group invisible="state != 'done'">
                        <field name="txt_filename" invisible="1"/>
                        <field name="txt_file" filename="txt_filename" readonly="1" string="Descargar Archivo"/>
                    </group>

                    <group invisible="state != 'done'">
                        <field name="mark_as_declared" widget="boolean_toggle"/>
                    </group>

                    <field name="wh_iva_ids" invisible="1"/>
                    <field name="state" invisible="1"/>
                </sheet>
                <footer>
                    <button name="action_generate_txt" 
                            string="Generar y Descargar" 
                            type="object" 
                            class="btn-primary" 
                            invisible="state != 'draft'"/>
                    
                    <button name="action_confirm_declared" 
                            string="Confirmar y Cerrar" 
                            type="object" 
                            class="btn-primary" 
                            invisible="state != 'done'"/>
                    
                    <button string="Cancelar" class="btn-secondary" special="cancel" invisible="state != 'draft'"/>
                    <button string="Cerrar sin declarar" class="btn-secondary" special="cancel" invisible="state != 'done'"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ACCIÓN DE SERVIDOR PARA EL MENÚ ACCIONES -->
    <record id="action_generate_iva_txt_seniat" model="ir.actions.server">
        <field name="name">Generar txt Seniat</field>
        <field name="model_id" ref="model_account_wh_iva_summary"/>
        <field name="binding_model_id" ref="model_account_wh_iva_summary"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
action = records.env['account.wh.iva.txt.export.wizard'].create({
    'wh_iva_ids': [(6, 0, records.mapped('line_ids').ids)]
}).action_generate_txt()
        </field>
    </record>
</odoo>
