<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Plantilla de Correo para Retención de IVA -->
        <record id="email_template_wh_iva" model="mail.template">
            <field name="name">Retención de IVA: Envío de Comprobante</field>
            <field name="model_id" ref="l10n_ve_simplit_fiscal.model_account_wh_iva_summary"/>
            <field name="subject">Comprobante de Retención de IVA: {{ object.name }}</field>
            <field name="email_from">{{ (object.company_id.partner_id.email_formatted or user.email_formatted) }}</field>
            <field name="partner_to">{{ object.partner_id.id }}</field>
            <field name="description">Plantilla para el envío de comprobantes de retención de IVA a proveedores.</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        Estimado/a <t t-out="object.partner_id.name or ''">Proveedor</t>,<br/><br/>
        Adjunto encontrará el comprobante de retención de IVA nro. <strong><t t-out="object.name or ''"/></strong> 
        correspondiente al periodo fiscal <t t-out="object.date and object.date.strftime('%m/%Y') or ''"/>.
        <br/><br/>
        <strong>Detalle del Comprobante:</strong>
        <ul>
            <li>Monto Total Factura: <t t-out="format_amount(object.amount_total_invoice, object.currency_id) or ''"/></li>
            <li>Monto Retenido: <t t-out="format_amount(object.amount_total_ret, object.currency_id) or ''"/></li>
        </ul>
        <br/>
        Si tiene alguna duda, por favor contáctenos.
        <br/><br/>
        Atentamente,
        <br/>
        <t t-out="object.company_id.name or ''"/>
    </p>
</div>
            </field>
            <field name="report_template_ids" eval="[(4, ref('l10n_ve_simplit_fiscal.action_report_wh_iva'))]"/>
            <field name="lang">{{ object.partner_id.lang }}</field>
            <field name="auto_delete" eval="False"/>
        </record>
        <!-- Plantilla de Correo para Retención de ISLR -->
        <record id="email_template_wh_islr" model="mail.template">
