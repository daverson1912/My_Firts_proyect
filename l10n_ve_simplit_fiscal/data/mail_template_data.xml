        <br/><br/>
        Atentamente,
        <br/>
        <t t-out="object.company_id.name or ''"/>
    </p>
</div>
            </field>
            <field name="report_template_ids" eval="[(4, ref('l10n_ve_simplit_fiscal.action_report_wh_islr'))]"/>
            <field name="lang">{{ object.partner_id.lang }}</field>
            <field name="auto_delete" eval="False"/>
        </record>
    </data>
</odoo>
