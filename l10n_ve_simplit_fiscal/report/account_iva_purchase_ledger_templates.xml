<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_purchase_ledger">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <div class="article" style="font-family: Arial, sans-serif; font-size: 6.5px; color: #000; width: 100%;">

                    <style>
                        table, tr, td, th, tbody, thead { border-collapse: collapse; }
                        * { box-sizing: border-box; }
                    </style>

                    <!-- ===== ENCABEZADO ===== -->
                    <table style="width: 100%; border: 0; margin-bottom: 10px;">
                        <tr>
                            <td style="width: 35%; vertical-align: top;">
                                <div style="font-weight: bold; font-size: 9px;"><t t-esc="o.company_id.name"/></div>
                                <div style="font-size: 6.5px;"><t t-esc="o.company_id.street or ''"/><t t-if="o.company_id.city">, <t t-esc="o.company_id.city"/></t></div>
                                <div style="font-size: 6.5px;"><t t-esc="o.company_id.vat or ''"/></div>
                            </td>
                            <td style="width: 40%; text-align: center; vertical-align: middle;">
                                <div style="font-weight: bold; font-size: 11px;">Libro de Compras  I.V.A.</div>
                                <div style="font-size: 7px; margin-top: 3px;">
                                    desde : <t t-esc="o.date_from.strftime('%d/%m/%Y')"/>
                                    &#160;&#160;&#160;
                                    hasta <t t-esc="o.date_to.strftime('%d/%m/%Y')"/>
                                </div>
                            </td>
                            <td style="width: 25%; text-align: right; vertical-align: top; font-size: 6.5px;">
                                <div>Página 1 de 1</div>
                                <div><t t-esc="o.date_print.strftime('%d/%m/%Y')"/></div>
                            </td>
                        </tr>
                    </table>

                    <!-- Acumuladores de totales -->
                    <t t-set="total_total"      t-value="0.0"/>
                    <t t-set="total_exento"     t-value="0.0"/>
                    <t t-set="total_base_16"    t-value="0.0"/>
                    <t t-set="total_iva_16"     t-value="0.0"/>
                    <t t-set="total_imp_base"   t-value="0.0"/>
                    <t t-set="total_imp_iva"    t-value="0.0"/>
                    <t t-set="total_imp_exento" t-value="0.0"/>
                    <t t-set="total_retenido"   t-value="0.0"/>

                    <!-- ===== TABLA ===== -->
                    <table style="width: 100%; border-collapse: collapse; font-size: 5.5px;">
                        <colgroup>
                            <col style="width: 2%;"/>   <!-- Nro Ope -->
                            <col style="width: 5%;"/>   <!-- Fecha -->
                            <col style="width: 7%;"/>   <!-- RIF -->
                            <col style="width: 13%;"/>  <!-- Nombre -->
                            <col style="width: 7%;"/>   <!-- Numero Docum -->
                            <col style="width: 3%;"/>   <!-- Tipo Doc -->
                            <col style="width: 7%;"/>   <!-- Numero Control -->
                            <col style="width: 4%;"/>   <!-- Tipo Tran -->
                            <col style="width: 7%;"/>   <!-- Nro Fac Afectada -->
                            <col style="width: 7%;"/>   <!-- Total c/IVA -->
                            <col style="width: 7%;"/>   <!-- Compras Exentas -->
                            <col style="width: 8%;"/>   <!-- Base Imponible -->
                            <col style="width: 3%;"/>   <!-- % -->
                            <col style="width: 7%;"/>   <!-- Monto IVA -->
                            <col style="width: 6%;"/>   <!-- Monto Retenido -->
                            <col style="width: 3%;"/>   <!-- % Ret -->
                            <col style="width: 5%;"/>   <!-- Nro Comp -->
                            <col style="width: 5%;"/>   <!-- Fecha Ret -->
                        </colgroup>
                        <thead>
                            <!-- Fila 1: grupos de sección -->
                            <tr style="text-align: center; font-weight: bold; font-size: 5.5px; border-top: 0.5px solid #000; border-bottom: 0.5px solid #000;">
                                <th colspan="11" style="padding: 2px;"></th>
                                <th colspan="3" style="padding: 2px; border-left: 0.5px solid #000; border-right: 0.5px solid #000;">Compras internas por alicuota general</th>
                                <th colspan="4" style="padding: 2px;">Retencion IVA</th>
                            </tr>
                            <!-- Fila 2: nombres de columna -->
                            <tr style="text-align: center; font-weight: bold; font-size: 5px; background-color: #f2f2f2; border-bottom: 0.5px solid #000;">
                                <th style="padding: 2px;">Nro<br/>Ope</th>
                                <th style="padding: 2px;">Fecha</th>
                                <th style="padding: 2px;">R.I.F.</th>
                                <th style="padding: 2px;">Nombre o razón social</th>
                                <th style="padding: 2px;">Numero<br/>Docum.</th>
                                <th style="padding: 2px;">Tipo<br/>Doc.</th>
                                <th style="padding: 2px;">Numero<br/>Control</th>
                                <th style="padding: 2px;">Tipo<br/>Tran.</th>
                                <th style="padding: 2px;">Nro. Fac.<br/>Afectada</th>
                                <th style="padding: 2px;">Total Compras<br/>incluyendo IVA</th>
                                <th style="padding: 2px;">Compras Exentas<br/>o sin crédito fisc.</th>
                                <th style="padding: 2px; border-left: 0.5px solid #000;">Base<br/>Imponible</th>
                                <th style="padding: 2px;">%</th>
                                <th style="padding: 2px; border-right: 0.5px solid #000;">Monto</th>
                                <th style="padding: 2px;">Monto<br/>retenido</th>
                                <th style="padding: 2px;">% Ret</th>
                                <th style="padding: 2px;">Nro. de<br/>Comp.</th>
                                <th style="padding: 2px;">Fecha</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="lines" t-value="o._get_ledger_data()"/>
                            <t t-foreach="lines" t-as="l">
                                <!-- Acumular totales separando importaciones de internas -->
                                <t t-set="total_total"   t-value="total_total + l.get('total_with_iva', 0.0)"/>
                                <t t-set="total_retenido" t-value="total_retenido + l.get('wh_amount', 0.0)"/>
                                <t t-if="l.get('is_import')">
                                    <t t-set="total_imp_base"   t-value="total_imp_base   + l.get('taxable_base', 0.0)"/>
                                    <t t-set="total_imp_iva"    t-value="total_imp_iva    + l.get('iva_amount', 0.0)"/>
                                    <t t-set="total_imp_exento" t-value="total_imp_exento + l.get('exempt_amount', 0.0)"/>
                                </t>
                                <t t-if="not l.get('is_import')">
                                    <t t-set="total_base_16" t-value="total_base_16 + l.get('base_16', 0.0)"/>
                                    <t t-set="total_iva_16"  t-value="total_iva_16  + l.get('iva_16', 0.0)"/>
                                    <t t-set="total_exento"  t-value="total_exento  + l.get('exempt_amount', 0.0)"/>
                                </t>

                                <tr style="text-align: center;">
                                    <td style="padding: 1px;"><t t-esc="l['ope']"/></td>
                                    <td style="padding: 1px;"><t t-esc="l['date'].strftime('%d/%m/%Y')"/></td>
                                    <td style="padding: 1px;"><t t-esc="l['rif']"/></td>
                                    <td style="padding: 1px; text-align: left;"><t t-esc="l['partner_name']"/></td>
                                    <td style="padding: 1px;"><t t-esc="l['doc_number']"/></td>
                                    <td style="padding: 1px;"><t t-esc="l['doc_type']"/></td>
                                    <td style="padding: 1px;"><t t-esc="l['control_number']"/></td>
                                    <td style="padding: 1px;"><t t-esc="l['tran_type']"/></td>
                                    <td style="padding: 1px;"><t t-esc="l['affected_doc']"/></td>
                                    <td style="padding: 1px; text-align: right;"><t t-esc="'{:,.2f}'.format(l['total_with_iva']).replace(',', 'X').replace('.', ',').replace('X', '.')"/></td>
                                    <td style="padding: 1px; text-align: right;"><t t-esc="'{:,.2f}'.format(l.get('exempt_amount', 0.0)).replace(',', 'X').replace('.', ',').replace('X', '.')"/></td>
                                    <td style="padding: 1px; text-align: right; border-left: 0.5px solid #000;"><t t-esc="'{:,.2f}'.format(l.get('taxable_base', 0.0)).replace(',', 'X').replace('.', ',').replace('X', '.')"/></td>
                                    <td style="padding: 1px; text-align: right;"><t t-esc="'{:.2f}'.format(l.get('iva_rate', 16.0))"/></td>
                                    <td style="padding: 1px; text-align: right; border-right: 0.5px solid #000;"><t t-esc="'{:,.2f}'.format(l.get('iva_amount', 0.0)).replace(',', 'X').replace('.', ',').replace('X', '.')"/></td>
                                    <td style="padding: 1px; text-align: right;"><t t-esc="'{:,.2f}'.format(l.get('wh_amount', 0.0)).replace(',', 'X').replace('.', ',').replace('X', '.')"/></td>
                                    <td style="padding: 1px; text-align: right;"><t t-esc="'{:.0f}'.format(l.get('wh_rate', 0.0)) if l.get('wh_rate') else ''"/></td>
                                    <td style="padding: 1px;"><t t-esc="l.get('wh_number', '') or 0"/></td>
                                    <td style="padding: 1px;"><t t-esc="l['wh_date'].strftime('%d/%m/%Y') if l.get('wh_date') else ''"/></td>
                                </tr>
                            </t>

                            <!-- Fila de totales -->
                            <tr style="font-weight: bold; border-top: 0.5px solid #000; text-align: right; font-size: 5.5px;">
                                <td colspan="9" style="padding: 1px;"></td>
                                <td style="padding: 1px;"><t t-esc="'{:,.2f}'.format(total_total).replace(',', 'X').replace('.', ',').replace('X', '.')"/></td>
                                <td style="padding: 1px;"><t t-esc="'{:,.2f}'.format(total_exento + total_imp_exento).replace(',', 'X').replace('.', ',').replace('X', '.')"/></td>
                                <td style="padding: 1px; border-left: 0.5px solid #000;"><t t-esc="'{:,.2f}'.format(total_base_16 + total_imp_base).replace(',', 'X').replace('.', ',').replace('X', '.')"/></td>
                                <td style="padding: 1px;"></td>
                                <td style="padding: 1px; border-right: 0.5px solid #000;"><t t-esc="'{:,.2f}'.format(total_iva_16 + total_imp_iva).replace(',', 'X').replace('.', ',').replace('X', '.')"/></td>
                                <td style="padding: 1px;"><t t-esc="'{:,.2f}'.format(total_retenido).replace(',', 'X').replace('.', ',').replace('X', '.')"/></td>
                                <td colspan="3" style="padding: 1px;"></td>
                            </tr>
                        </tbody>
                    </table>

                    <!-- ===== RESUMEN DE CRÉDITOS FISCALES ===== -->
                    <div style="margin-top: 16px;">
                        <table style="border-collapse: collapse; font-size: 6.5px;">
                            <tr>
                                <td style="padding: 2px; font-weight: bold; font-size: 8px;" colspan="3">Resumen de Creditos Fiscales</td>
                                <td style="padding: 2px; font-weight: bold; text-align: center; min-width: 90px;">Base Imponible</td>
                                <td style="padding: 2px; font-weight: bold; text-align: center; min-width: 90px;">Credito Fiscal</td>
                            </tr>
                            <tr>
                                <td style="padding: 1px 4px;" colspan="3">Compras internas gravadas alicuota general (16%)</td>
                                <td style="padding: 1px 4px; text-align: right;"><t t-esc="'{:,.2f}'.format(total_base_16).replace(',', 'X').replace('.', ',').replace('X', '.')"/></td>
                                <td style="padding: 1px 4px; text-align: right;"><t t-esc="'{:,.2f}'.format(total_iva_16).replace(',', 'X').replace('.', ',').replace('X', '.')"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 1px 4px;" colspan="3">Importación gravadas por alicuota general (16%)</td>
                                <td style="padding: 1px 4px; text-align: right;"><t t-esc="'{:,.2f}'.format(total_imp_base).replace(',', 'X').replace('.', ',').replace('X', '.')"/></td>
                                <td style="padding: 1px 4px; text-align: right;"><t t-esc="'{:,.2f}'.format(total_imp_iva).replace(',', 'X').replace('.', ',').replace('X', '.')"/></td>
                            </tr>
                            <tr style="font-weight: bold; border-top: 0.5px solid #000; border-bottom: 0.5px solid #000;">
                                <td style="padding: 2px 4px;" colspan="3">Total Compras y créditos fiscales del período</td>
                                <td style="padding: 2px 4px; text-align: right;"><t t-esc="'{:,.2f}'.format(total_base_16 + total_imp_base).replace(',', 'X').replace('.', ',').replace('X', '.')"/></td>
                                <td style="padding: 2px 4px; text-align: right;"><t t-esc="'{:,.2f}'.format(total_iva_16 + total_imp_iva).replace(',', 'X').replace('.', ',').replace('X', '.')"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 1px 4px;" colspan="3">Compras no gravadas y/o sin derecho a credito fiscal</td>
                                <td style="padding: 1px 4px; text-align: right;"><t t-esc="'{:,.2f}'.format(total_exento + total_imp_exento).replace(',', 'X').replace('.', ',').replace('X', '.')"/></td>
                                <td style="padding: 1px 4px;"></td>
                            </tr>
                        </table>
                    </div>

                </div>
            </t>
        </t>
    </template>
</odoo>
