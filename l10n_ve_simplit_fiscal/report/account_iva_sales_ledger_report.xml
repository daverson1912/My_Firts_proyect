        <field name="report_type">qweb-pdf</field>
        <field name="report_name">l10n_ve_simplit_fiscal.report_sales_ledger_detailed</field>
        <field name="report_file">l10n_ve_simplit_fiscal.report_sales_ledger_detailed</field>
        <field name="print_report_name">'Libro_Ventas_Detallado_%s' % object.id</field>
        <field name="binding_model_id" eval="False"/>
        <field name="paperformat_id" ref="l10n_ve_simplit_fiscal.paperformat_wh_iva"/>
    </record>
</odoo>
