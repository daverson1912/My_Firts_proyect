<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista de Lista (Tree View) -->
    <record id="view_my_custom_model_tree" model="ir.ui.view">
        <field name="name">my_custom.model.tree</field>
        <field name="model">my_custom.model</field>
        <field name="arch" type="xml">
            <list string="Modelos Personalizados">
                <field name="name"/>
                <field name="description"/>
                <field name="comentario"/>
                <field name="fecha_registro"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Vista de Formulario (Form View) -->
    <record id="view_my_custom_model_form" model="ir.ui.view">
        <field name="name">my_custom.model.form</field>
        <field name="model">my_custom.model</field>
        <field name="arch" type="xml">
            <form string="Modelo Personalizado">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="comentario"/>
                        <field name="fecha_registro"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción de Ventana (Window Action) -->
    <record id="action_my_custom_model" model="ir.actions.act_window">
        <field name="name">Mi Modelo Personalizado</field>
        <field name="res_model">my_custom.model</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea el primer registro personalizado.
            </p>
        </field>
    </record>

    <!-- Menús de Acceso -->
    <menuitem id="menu_my_custom_root" name="Mi Módulo" sequence="10" web_icon="my_custom_module,static/description/icon.png"/>
    <menuitem id="menu_my_custom_model" name="Registros" parent="menu_my_custom_root" action="action_my_custom_model" sequence="10"/>
</odoo>
