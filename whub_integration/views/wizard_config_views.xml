<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_whub_config_wizard_form" model="ir.ui.view">
        <field name="name">whub.config.wizard.form</field>
        <field name="model">whub.config.wizard</field>
        <field name="arch" type="xml">
            <form string="Conexión con WispHub">
                <group>
                    <p class="text-muted">
                        Ingrese su llave de acceso (API Key) para validar la conexión con WispHub.
                    </p>
                    <field name="api_key" password="True" placeholder="Pegue la llave aquí..."/>
                </group>
                <footer>
                    <button name="action_test_connection" string="Validar y Guardar" type="object" class="btn-primary" icon="fa-bolt"/>

                    <button string="Cerrar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
