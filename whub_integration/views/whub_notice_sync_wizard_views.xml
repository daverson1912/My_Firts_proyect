<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista Formulario del Wizard -->
    <record id="view_whub_notice_sync_wizard_form" model="ir.ui.view">
        <field name="name">whub.notice.sync.wizard.form</field>
        <field name="model">whub.notice.sync.wizard</field>
        <field name="arch" type="xml">
            <form string="Sincronizar Avisos de Cobro">
                <sheet>
                    <group>
                        <field name="date_from" string="Punto de Inicio"/>
                    </group>
                    <div class="alert alert-info" role="alert">
                        Se traerán todas las órdenes de venta desde este punto de inicio hasta ahora.
                        Luego, el cron automático continuará cada 20 minutos desde la fecha/hora de la
                        última orden encontrada.
                    </div>
                </sheet>
                <footer>
                    <button name="action_sync_from_date" string="Sincronizar" type="object" class="oe_highlight"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Acción para abrir el wizard -->
    <record id="action_whub_notice_sync_wizard" model="ir.actions.act_window">
        <field name="name">Sincronizar Avisos de Cobro</field>
        <field name="res_model">whub.notice.sync.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
