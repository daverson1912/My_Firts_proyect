<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista Formulario del Wizard -->
    <record id="view_whub_notice_sync_wizard_form" model="ir.ui.view">
        <field name="name">whub.notice.sync.wizard.form</field>
        <field name="model">whub.notice.sync.wizard</field>
        <field name="arch" type="xml">
            <form string="Consultar Avisos por Fechas">
                <sheet>
                    <group>
                        <group string="Rango de Fechas">
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                        <group string="Margen de Búsqueda">
                            <field name="days_back"/>
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert">
                        Este wizard sincronizará los avisos de cobro de WispHub en el rango de fechas seleccionado.
                    </div>
                </sheet>
                <footer>
                    <button name="action_sync_by_dates" string="Consultar Avisos" type="object" class="oe_highlight"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Acción para abrir el wizard -->
    <record id="action_whub_notice_sync_wizard" model="ir.actions.act_window">
        <field name="name">Consultar Avisos por Fechas</field>
        <field name="res_model">whub.notice.sync.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
