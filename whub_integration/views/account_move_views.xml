<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extensión de la vista de Facturas de Cliente para WispHub -->
    <record id="view_move_form_whub_inherit" model="ir.ui.view">
        <field name="name">account.move.form.whub.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Botón de Simulación de Pago (Persona Jurídica con Diferencial Cambiario) -->
            <xpath expr="//header" position="inside">
                <button name="action_whub_simulate_company_payment" 
                        string="Simular Pago (Diferencial Cambiario WispHub)" 
                        type="object" 
                        class="btn-secondary" 
                        invisible="not whub_invoice_id or state != 'posted' or payment_state not in ('not_paid', 'partial')"/>
            </xpath>

            <!-- Mostrar el ID de WispHub en la pestaña de Información General -->
            <xpath expr="//field[@name='payment_reference']" position="after">
                <field name="whub_invoice_id" readonly="1" invisible="not whub_invoice_id"/>
            </xpath>
        </field>
    </record>
</odoo>
