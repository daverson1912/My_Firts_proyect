<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_whub_homologation_wizard_form" model="ir.ui.view">
        <field name="name">whub.homologation.wizard.form</field>
        <field name="model">whub.homologation.wizard</field>
        <field name="arch" type="xml">
            <form string="Homologación WispHub" create="0" delete="0">
                <header>
                    <button name="action_return_to_settings" string=" Volver" type="object" class="btn-secondary" icon="fa-arrow-left"/>
                    <button name="action_load_wisphub_data" string="Traer datos de WispHub" type="object" class="btn-primary" icon="fa-refresh" 
                            confirm="Esta acción sincronizará los datos más recientes desde WispHub (categorías, productos, planes y clientes). Los vínculos de homologación que no hayan sido guardados se perderán. ¿Desea continuar?"/>
                </header>

                <sheet>
                    <!-- Campos técnicos para control de visibilidad -->
                    <field name="active_section" invisible="1"/>
                    <field name="has_selection" invisible="1"/>

                    <div class="oe_title mb-3">
                        <h1 class="text-primary">Sincronizador Odoo y WispHub</h1>
                        <p class="text-muted mt-1" style="font-size: 0.92rem;">
                            <i class="fa fa-info-circle me-1" style="color: #00A99D;"/>
                            Marque con el check los registros que desea procesar y utilice los botones
                            <strong>Homologar</strong> (para vincularlos a registros existentes en Odoo) o
                            <strong>Crear en Odoo</strong> (para generarlos automáticamente).
                        </p>
                    </div>

                    <!-- BARRA DE PESTAÑAS PERSONALIZADA -->
                    <div class="d-flex mb-3 border-bottom pb-2" style="gap: 10px;">
                        <button name="action_switch_tab" context="{'active_section': 'category'}" type="object" class="btn btn-sm" 
                                invisible="active_section == 'category'" style="border: none; border-bottom: 2px solid transparent; border-radius: 0; color: #666;">
                            <i class="fa fa-folder-open-o me-1"/> Categorías
                        </button>
                        <div class="btn btn-sm fw-bold" invisible="active_section != 'category'" 
                             style="border: none; border-bottom: 2px solid #00A99D; border-radius: 0; color: #00A99D;">
                            <i class="fa fa-folder-open-o me-1"/> Categorías
                        </div>

                        <button name="action_switch_tab" context="{'active_section': 'product'}" type="object" class="btn btn-sm" 
                                invisible="active_section == 'product'" style="border: none; border-bottom: 2px solid transparent; border-radius: 0; color: #666;">
                            <i class="fa fa-cube me-1"/> Productos
                        </button>
                        <div class="btn btn-sm fw-bold" invisible="active_section != 'product'" 
                             style="border: none; border-bottom: 2px solid #00A99D; border-radius: 0; color: #00A99D;">
                            <i class="fa fa-cube me-1"/> Productos
                        </div>

                        <button name="action_switch_tab" context="{'active_section': 'plan'}" type="object" class="btn btn-sm" 
                                invisible="active_section == 'plan'" style="border: none; border-bottom: 2px solid transparent; border-radius: 0; color: #666;">
                            <i class="fa fa-list-alt me-1"/> Planes / Adicionales
                        </button>
                        <div class="btn btn-sm fw-bold" invisible="active_section != 'plan'" 
                             style="border: none; border-bottom: 2px solid #00A99D; border-radius: 0; color: #00A99D;">
                            <i class="fa fa-list-alt me-1"/> Planes / Adicionales
                        </div>

                        <button name="action_switch_tab" context="{'active_section': 'customer'}" type="object" class="btn btn-sm" 
                                invisible="active_section == 'customer'" style="border: none; border-bottom: 2px solid transparent; border-radius: 0; color: #666;">
                            <i class="fa fa-users me-1"/> Clientes
                        </button>
                        <div class="btn btn-sm fw-bold" invisible="active_section != 'customer'" 
                             style="border: none; border-bottom: 2px solid #00A99D; border-radius: 0; color: #00A99D;">
                            <i class="fa fa-users me-1"/> Clientes
                        </div>
                    </div>

                    <!-- CONTENIDO: CATEGORÍAS -->
                    <div invisible="active_section != 'category'">
                        <div class="row align-items-center mb-3">
                            <div class="col-4">
                                <div class="alert alert-info py-1 mb-0" style="background-color: rgba(0, 169, 157, 0.1); border-left: 3px solid #00A99D;">
                                    <i class="fa fa-calendar me-2"/> Sinc: <field name="sync_cat"/>
                                </div>
                            </div>
                            <div class="col-4">
                                <field name="search_cat" placeholder="Buscar categoría..." class="oe_inline w-100"/>
                            </div>
                            <div class="col-4 text-end">
                                <button name="action_open_batch_homologation" string=" Homologar" type="object" class="btn btn-sm btn-primary" icon="fa-link"/>
                                <button name="action_create_selected" string=" Crear" type="object" class="btn btn-sm btn-info" icon="fa-plus-circle"/>
                                <button name="action_toggle_selection_main" context="{'active_section': 'category'}" string=" Marcar Pendientes" type="object" class="btn btn-secondary btn-sm" icon="fa-check-square-o"/>
                                <button name="action_unmark_all" context="{'active_section': 'category'}" string=" Desmarcar Todos" type="object" class="btn btn-link btn-sm text-muted" icon="fa-square-o"/>
                            </div>
                        </div>
                        <field name="filtered_category_line_ids" readonly="0">
                            <list editable="bottom" create="false" delete="false" limit="80">
                                <field name="is_selected" string="Seleccionado" width="100px" readonly="0"/>
                                <field name="whub_category_name" readonly="1" decoration-bf="1" string="Categoría WispHub" optional="show"/>
                                <field name="odoo_category_id" string="Categoría Odoo" readonly="1" optional="show"/>
                            </list>
                        </field>
                    </div>

                    <!-- CONTENIDO: PRODUCTOS -->
                    <div invisible="active_section != 'product'">
                        <div class="row align-items-center mb-3">
                            <div class="col-4">
                                <div class="alert alert-info py-1 mb-0" style="background-color: rgba(0, 169, 157, 0.1); border-left: 3px solid #00A99D;">
                                    <i class="fa fa-calendar me-2"/> Sinc: <field name="sync_prod"/>
                                </div>
                            </div>
                            <div class="col-4">
                                <field name="search_prod" placeholder="Buscar producto..." class="oe_inline w-100"/>
                            </div>
                            <div class="col-4 text-end">
                                <button name="action_open_batch_homologation" string=" Homologar" type="object" class="btn btn-sm btn-primary" icon="fa-link"/>
                                <button name="action_create_selected" string=" Crear" type="object" class="btn btn-sm btn-info" icon="fa-plus-circle"/>
                                <button name="action_toggle_selection_main" context="{'active_section': 'product'}" string=" Marcar Pendientes" type="object" class="btn btn-secondary btn-sm" icon="fa-check-square-o"/>
                                <button name="action_unmark_all" context="{'active_section': 'product'}" string=" Desmarcar Todos" type="object" class="btn btn-link btn-sm text-muted" icon="fa-square-o"/>
                            </div>
                        </div>
                        <field name="filtered_product_line_ids" readonly="0">
                            <list editable="bottom" create="false" delete="false" limit="80">
                                <field name="is_selected" string="Seleccionado" width="100px" readonly="0"/>
                                <field name="whub_product_name" readonly="1" decoration-bf="1" string="Producto WispHub" optional="show"/>
                                <field name="whub_description" readonly="1" string="Descripción WispHub" optional="show"/>
                                <field name="whub_category_name" readonly="1" widget="badge" string="Categoría WispHub" optional="show"/>
                                <field name="odoo_product_id" string="Producto Odoo" readonly="1" optional="show"/>
                                <field name="odoo_product_categ_name" readonly="1" string="Categoría Odoo" optional="show"/>
                                <field name="whub_product_id" optional="hide" readonly="1" string="ID WispHub"/>
                            </list>
                        </field>
                    </div>

                    <!-- CONTENIDO: PLANES -->
                    <div invisible="active_section != 'plan'">
                        <div class="row align-items-center mb-3">
                            <div class="col-4">
                                <div class="alert alert-info py-1 mb-0" style="background-color: rgba(0, 169, 157, 0.1); border-left: 3px solid #00A99D;">
                                    <i class="fa fa-calendar me-2"/> Sinc: <field name="sync_plan"/>
                                </div>
                            </div>
                            <div class="col-4">
                                <field name="search_plan" placeholder="Buscar plan..." class="oe_inline w-100"/>
                            </div>
                            <div class="col-4 text-end">
                                <button name="action_open_batch_homologation" string=" Homologar" type="object" class="btn btn-sm btn-primary" icon="fa-link"/>
                                <button name="action_create_selected" string=" Crear" type="object" class="btn btn-sm btn-info" icon="fa-plus-circle"/>
                                <button name="action_toggle_selection_main" context="{'active_section': 'plan'}" string=" Marcar Pendientes" type="object" class="btn btn-secondary btn-sm" icon="fa-check-square-o"/>
                                <button name="action_unmark_all" context="{'active_section': 'plan'}" string=" Desmarcar Todos" type="object" class="btn btn-link btn-sm text-muted" icon="fa-square-o"/>
                            </div>
                        </div>
                        <field name="filtered_plan_line_ids" readonly="0">
                            <list editable="bottom" create="false" delete="false" limit="80">
                                <field name="is_selected" string="Seleccionado" width="100px" readonly="0"/>
                                <field name="whub_plan_name" readonly="1" decoration-bf="1" string="Plan WispHub" optional="show"/>
                                <field name="whub_type" widget="badge" string="Tipo" decoration-info="whub_type == 'Internet'" decoration-warning="whub_type == 'Adicional'" optional="show"/>
                                <field name="odoo_product_id" string="Producto Odoo" readonly="1" optional="show"/>
                                <field name="whub_plan_id" optional="hide" readonly="1" string="ID WispHub"/>
                            </list>
                        </field>
                    </div>

                    <!-- CONTENIDO: CLIENTES -->
                    <div invisible="active_section != 'customer'">
                        <div class="row align-items-center mb-3">
                            <div class="col-4">
                                <div class="alert alert-info py-1 mb-0" style="background-color: rgba(0, 169, 157, 0.1); border-left: 3px solid #00A99D;">
                                    <i class="fa fa-calendar me-2"/> Sinc: <field name="sync_cust"/>
                                </div>
                            </div>
                            <div class="col-4">
                                <field name="search_cust" placeholder="Buscar cliente..." class="oe_inline w-100"/>
                            </div>
                            <div class="col-4 text-end">
                                <button name="action_open_batch_homologation" string=" Homologar" type="object" class="btn btn-sm btn-primary" icon="fa-link"/>
                                <button name="action_create_selected" string=" Crear" type="object" class="btn btn-sm btn-info" icon="fa-plus-circle"/>
                                <button name="action_toggle_selection_main" context="{'active_section': 'customer'}" string=" Marcar Pendientes" type="object" class="btn btn-secondary btn-sm" icon="fa-check-square-o"/>
                                <button name="action_unmark_all" context="{'active_section': 'customer'}" string=" Desmarcar Todos" type="object" class="btn btn-link btn-sm text-muted" icon="fa-square-o"/>
                            </div>
                        </div>
                        <field name="filtered_customer_line_ids" readonly="0">
                            <list editable="bottom" create="false" delete="false" limit="80">
                                <field name="is_selected" string="Seleccionado" width="100px" readonly="0"/>
                                <field name="whub_customer_name" readonly="1" decoration-bf="1" string="Cliente WispHub" optional="show"/>
                                <field name="whub_fiscal_id" string="Cédula/RIF" readonly="1" optional="show"/>
                                <field name="whub_phone" string="Teléfono" readonly="1" optional="hide"/>
                                <field name="whub_email" string="Email" readonly="1" optional="hide"/>
                                <field name="odoo_partner_id" string="Contacto Odoo" readonly="1" optional="show"/>
                                <field name="whub_customer_id" optional="hide" readonly="1" string="ID WispHub"/>
                            </list>
                        </field>
                    </div>
                </sheet>
                <footer>
                    <button string="Cerrar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_whub_homologation_batch_wizard_form" model="ir.ui.view">
        <field name="name">whub.homologation.batch.wizard.form</field>
        <field name="model">whub.homologation.batch.wizard</field>
        <field name="arch" type="xml">
            <form string="Homologar Seleccionados">
                <sheet>
                    <div class="alert alert-info py-3 mb-3">
                        <h5 class="alert-heading mb-2"><i class="fa fa-link me-2"/>Homologación de Registros por Lote</h5>
                        <p class="mb-0">Seleccione el registro de Odoo correspondiente para cada uno de los elementos marcados. Esto establecerá el vínculo de homologación en la base de datos.</p>
                    </div>
                    <field name="res_type" invisible="1"/>
                    <field name="line_ids">
                        <list editable="bottom" create="false" delete="false">
                            <field name="name" string="Elemento de WispHub" readonly="1"/>
                            <field name="whub_description" readonly="1" string="Descripción WispHub" optional="show"
                                   column_invisible="parent.res_type != 'product'"/>
                            <field name="whub_id" column_invisible="True"/>
                            <field name="res_type" column_invisible="True"/>
                            <field name="odoo_category_id" column_invisible="parent.res_type != 'category'" string="Categoría Odoo" options="{'no_create': True}"/>
                            <field name="odoo_product_id" column_invisible="parent.res_type != 'product'" string="Producto Odoo" options="{'no_create': True}"/>
                            <field name="odoo_plan_id" column_invisible="parent.res_type != 'plan'" string="Plan Odoo" options="{'no_create': True}"/>
                            <field name="odoo_partner_id" column_invisible="parent.res_type != 'customer'" string="Contacto Odoo" options="{'no_create': True}"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button name="action_confirm_batch_homologation" string="Confirmar y Guardar" type="object" class="btn-primary" icon="fa-check"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Vista de Creación Seleccionada -->
    <record id="view_whub_creation_selection_wizard_form" model="ir.ui.view">
        <field name="name">whub.creation.selection.wizard.form</field>
        <field name="model">whub.creation.selection.wizard</field>
        <field name="arch" type="xml">
            <form string="Confirmar Creación">
                <header>

                </header>
                <sheet>
                    <div class="alert alert-info py-3 mb-3">
                        <h5 class="alert-heading mb-2"><i class="fa fa-info-circle me-2"/>Asistente de Creación Automática</h5>
                        <p class="mb-0">Seleccione los elementos de WispHub que desea crear en Odoo de forma masiva. Para los productos, puede configurar cómo estructurar el nombre resultante (nombre original, nombre con descripción o solo descripción) en la columna <strong>Formato Nombre</strong>.</p>
                    </div>
                    <field name="has_product_lines" invisible="1"/>
                    <field name="line_ids">
                        <list editable="bottom" create="false" delete="false">
                            <field name="is_selected" string="Crear" class="text-center"/>
                            <field name="res_type" string="Tipo de Registro" readonly="1" class="text-center"/>
                            <field name="name" readonly="1"/>
                            <field name="whub_description" readonly="1" string="Descripción WispHub" optional="show"
                                   invisible="res_type != 'product'"
                                   column_invisible="not parent.has_product_lines"/>
                            <field name="creation_name_option" string="Formato Nombre"
                                   invisible="res_type != 'product'"
                                   column_invisible="not parent.has_product_lines"/>
                            <field name="whub_id" column_invisible="True"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button name="action_confirm_creation" string="Crear Seleccionados" type="object" class="btn-primary" icon="fa-plus"/>
                    <button name="action_return_to_settings" string="Volver" type="object" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
