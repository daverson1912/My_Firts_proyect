<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="module_category_tafel" model="ir.module.category">
            <field name="name">Facturación Electrónica</field>
            <field name="description">Acceso a la configuración de Facturación Electrónica Tafel.</field>
            <field name="sequence">100</field>
        </record>

        <record id="group_tafel_user" model="res.groups">
            <field name="name">Usuario</field>
            <field name="category_id" ref="module_category_tafel"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_tafel_manager" model="res.groups">
            <field name="name">Gerente</field>
            <field name="category_id" ref="module_category_tafel"/>
            <field name="implied_ids" eval="[(4, ref('group_tafel_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

    </data>
</odoo>
